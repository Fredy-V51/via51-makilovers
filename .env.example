# ====================================================
# Ejemplo de configuración - .env.example
# ====================================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. El archivo .env está en .gitignore - NO se subirá a git ✓

# ====================================================
# Firebase / Firestore Configuration
# ====================================================

# Ruta absoluta a las credenciales de Firebase
# Obtén el archivo JSON en Firebase Console:
# https://console.firebase.google.com 
#   → Tu Proyecto → ⚙️ Configuración → Cuentas de Servicio
#   → Generar nueva clave privada → Descarga el JSON
# Sube el archivo a Codespaces y referencia su ruta aquí:
GOOGLE_APPLICATION_CREDENTIALS="/ruta/absoluta/a/serviceAccountKey.json"

# Activa lectura desde Firestore en lugar de menu.json local
# - true: Usa Firestore como base de datos principal
# - false: Usa menu.json (solo lectura local)
USE_FIRESTORE=false

# ====================================================
# Server Configuration
# ====================================================

# Puerto HTTP para la API local
PORT=3000

# Ambiente de ejecución
# - development: Modo desarrollo con logs detallados
# - testing: Modo pruebas (desactiva ciertos features)
# - production: Modo producción (sin logs verbosos)
NODE_ENV=development
